# Root folder containing one subfolder per anime (episodes inside each).
# Tilde (~) is expanded server-side. Defaults to ~/Downloads/anime if unset.
ANIME_LIBRARY_PATH=~/Downloads/anime

# Where the app stores folder→AniList mappings and watched state (JSON).
ANIPLAYER_DATA_DIR=./.data

# AniList API v2 client (create one at https://anilist.co/settings/developer).
# Uses the Authorization Code grant: the client ID is public, the secret stays
# server-side. The redirect URL registered on AniList must match
# NEXT_PUBLIC_ANILIST_REDIRECT_URI exactly.
NEXT_PUBLIC_ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
NEXT_PUBLIC_ANILIST_REDIRECT_URI=http://localhost:39847/auth/callback
