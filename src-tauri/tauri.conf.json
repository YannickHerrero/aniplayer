{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aniplayer",
  "version": "0.1.0",
  "identifier": "dev.yannick.aniplayer",
  "build": {
    "frontendDist": "resources/next-server",
    "devUrl": "http://127.0.0.1:39847",
    "beforeDevCommand": "pnpm dev:desktop",
    "beforeBuildCommand": "pnpm desktop:prepare"
  },
  "app": {
    "windows": [
      {
        "title": "Aniplayer",
        "url": "http://127.0.0.1:39847",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/node"],
    "resources": ["resources/next-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
